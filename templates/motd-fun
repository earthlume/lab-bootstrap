#!/usr/bin/env bash
# Fun-tier MOTD
# Wraps the base MOTD with figlet/lolcat banner and fortune/cowsay.
# Every tool is guarded — degrades gracefully if anything is missing.
# Target: under 2 seconds total render on a Pi 5.
# shellcheck disable=SC2059 — ANSI codes in format strings are intentional

# Guard against double display (sourced by both profile.d and .zshrc)
if [[ -n "${_LAB_MOTD_SHOWN:-}" ]]; then return 0 2>/dev/null || exit 0; fi
export _LAB_MOTD_SHOWN=1

# Ensure tools are in PATH (profile.d runs before .zshrc sets up PATH)
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"
[[ -d /usr/games ]] && export PATH="$PATH:/usr/games"
[[ -d /usr/local/bin ]] && export PATH="$PATH:/usr/local/bin"

T='\033[38;5;30m'
R='\033[0m'

# Strip trailing blank lines from everything — each tool adds its own
# padding and the combined output gets too loose without this.
_lab_motd_render() {

# --- Figlet hostname banner (piped through lolcat if available) ---
if command -v figlet &>/dev/null; then
    BANNER="$(figlet -f small "$(hostname -s)" 2>/dev/null)"
    if [[ -n "$BANNER" ]] && command -v lolcat &>/dev/null; then
        echo "$BANNER" | lolcat -f 2>/dev/null
    elif [[ -n "$BANNER" ]]; then
        printf "${T}%s${R}\n" "$BANNER"
    fi
fi

# --- System info via fastfetch or pfetch ---
if command -v fastfetch &>/dev/null; then
    fastfetch --logo none --structure OS:Kernel:Uptime:Memory:Disk:LocalIP 2>/dev/null
elif command -v pfetch &>/dev/null; then
    PF_INFO="title os kernel uptime memory" pfetch 2>/dev/null
else
    # Fall back to the base MOTD box
    MOTD_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    BASE_MOTD=""
    for path in "$MOTD_SCRIPT_DIR/motd" /etc/update-motd.d/99-lab-motd /etc/profile.d/99-lab-motd.sh; do
        if [[ -x "$path" ]] && [[ "$(basename "$path")" != "$(basename "${BASH_SOURCE[0]}")" ]]; then
            BASE_MOTD="$path"
            break
        fi
    done
    if [[ -n "$BASE_MOTD" ]]; then
        "$BASE_MOTD"
    fi
fi

# --- Fortune + cowsay (if both available) ---
if command -v fortune &>/dev/null && command -v cowsay &>/dev/null; then
    QUOTE="$(fortune -s 2>/dev/null)"
    if [[ -n "$QUOTE" ]]; then
        if command -v lolcat &>/dev/null; then
            echo "$QUOTE" | cowsay -f small 2>/dev/null | lolcat -f 2>/dev/null
        else
            echo "$QUOTE" | cowsay -f small 2>/dev/null
        fi
    fi
fi

}

# Render and strip all trailing blank lines
_lab_motd_render | sed -e :a -e '/^\s*$/{ $d; N; ba; }'
unset -f _lab_motd_render
