#!/usr/bin/env bash
# lab.hoens.fun — dynamic MOTD
# Generates live system info with teal-accented Unicode box drawing

# Colors
T='\033[38;5;30m'   # teal
W='\033[1;37m'      # bright white
D='\033[0;37m'      # dim white
R='\033[0m'         # reset

# Gather system info
HOSTNAME_FULL="$(hostname -s).lab.hoens.fun"
OS_PRETTY="$(. /etc/os-release && echo "$PRETTY_NAME")"
ARCH="$(uname -m)"
UPTIME="$(uptime -p 2>/dev/null | sed 's/^up //' || uptime | sed 's/.*up//' | sed 's/,.*load.*//' | xargs)"

# IP — prefer 10.4.20.x, fall back to first non-loopback
IP="$(ip -4 addr show 2>/dev/null | grep -oP 'inet 10\.4\.20\.\K\d+' | head -1)"
if [[ -n "$IP" ]]; then
    IP="10.4.20.$IP"
else
    IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
fi

# CPU info
if [[ -f /proc/device-tree/model ]] && grep -q "Raspberry Pi" /proc/device-tree/model 2>/dev/null; then
    CPU_COUNT="$(nproc)"
    CPU_MODEL="$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "ARM")"
    CPU="${CPU_COUNT}× ${CPU_MODEL}"
else
    CPU_COUNT="$(nproc)"
    CPU_MODEL="$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "unknown")"
    CPU="${CPU_COUNT}× ${CPU_MODEL}"
fi

# Memory
MEM_TOTAL="$(free -h | awk '/^Mem:/{print $2}')"
MEM_USED="$(free -h | awk '/^Mem:/{print $3}')"
MEM_PCT="$(free | awk '/^Mem:/{printf "%.0f", $3/$2*100}')"

# Disk (root filesystem)
DISK_TOTAL="$(df -h / | awk 'NR==2{print $2}')"
DISK_USED="$(df -h / | awk 'NR==2{print $3}')"
DISK_PCT="$(df / | awk 'NR==2{gsub(/%/,""); print $5}')"

# Box width
BW=47

# Print
printf "\n"
printf "  ${T}┌─────────────────────────────────────────────┐${R}\n"
printf "  ${T}│${R}  ⚡ ${T}${W}%-43s${R}${T}│${R}\n" "$HOSTNAME_FULL"
printf "  ${T}│${R}  %-45s${T}│${R}\n" ""
printf "  ${T}│${R}  ${D}OS      ${W}%-36s${R}${T}│${R}\n" "$OS_PRETTY $ARCH"
printf "  ${T}│${R}  ${D}Uptime  ${W}%-36s${R}${T}│${R}\n" "$UPTIME"
printf "  ${T}│${R}  ${D}IP      ${W}%-36s${R}${T}│${R}\n" "$IP"
printf "  ${T}│${R}  ${D}CPU     ${W}%-36s${R}${T}│${R}\n" "$CPU"
printf "  ${T}│${R}  ${D}Memory  ${W}%-36s${R}${T}│${R}\n" "$MEM_USED / $MEM_TOTAL ($MEM_PCT%)"
printf "  ${T}│${R}  ${D}Disk    ${W}%-36s${R}${T}│${R}\n" "$DISK_USED / $DISK_TOTAL ($DISK_PCT%)"
printf "  ${T}└─────────────────────────────────────────────┘${R}\n"
printf "\n"
